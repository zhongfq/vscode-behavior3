{
  "name": "vscode-behavior3",
  "displayName": "Behavior Tree Editor",
  "description": "Visual behavior tree editor for game development",
  "version": "2.0.2",
  "publisher": "codetypes",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhongfq/vscode-behavior3"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "behavior3.treeEditor",
        "displayName": "Behavior Tree Editor",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "behavior3.build",
        "title": "Build Behavior Tree",
        "category": "Behavior Tree",
        "icon": "$(tools)"
      },
      {
        "command": "behavior3.createProject",
        "title": "Create Project",
        "category": "Behavior Tree"
      },
      {
        "command": "behavior3.openSettings",
        "title": "Open Node Config (.b3-setting)",
        "category": "Behavior Tree"
      },
      {
        "command": "behavior3.createTree",
        "title": "Create Behavior3 File",
        "category": "Behavior Tree"
      },
      {
        "command": "behavior3.openWithEditor",
        "title": "Open with Behavior3",
        "category": "Behavior Tree"
      },
      {
        "command": "behavior3.toggleEditorMode",
        "title": "Toggle Text / Behavior3",
        "category": "Behavior Tree",
        "icon": "$(edit)"
      }
    ],
    "keybindings": [
      {
        "command": "behavior3.build",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "activeCustomEditorId == 'behavior3.treeEditor'"
      },
      {
        "command": "behavior3.toggleEditorMode",
        "key": "f4",
        "when": "activeCustomEditorId == 'behavior3.treeEditor' || resourceExtname == .json"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "behavior3.toggleEditorMode",
          "when": "activeCustomEditorId == 'behavior3.treeEditor' || resourceExtname == .json",
          "group": "navigation@0"
        },
        {
          "command": "behavior3.build",
          "when": "activeCustomEditorId == 'behavior3.treeEditor'",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "behavior3.createTree",
          "when": "explorerResourceIsFolder",
          "group": "navigation@45"
        },
        {
          "command": "behavior3.openWithEditor",
          "when": "resourceExtname == .json && !explorerResourceIsFolder",
          "group": "navigation@45"
        }
      ]
    },
    "configuration": {
      "title": "Behavior Tree Editor",
      "properties": {
        "behavior3.settingFile": {
          "type": "string",
          "default": "",
          "description": "节点定义配置文件路径（相对工作区根目录）。留空时从当前打开的树文件所在目录向父级搜索到工作区根目录，使用第一个 *.b3-setting；若仍无则回退到工作区根目录下的 *.b3-setting"
        },
        "behavior3.checkExpr": {
          "type": "boolean",
          "default": true,
          "description": "启用表达式校验"
        },
        "behavior3.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh",
            "en"
          ],
          "enumDescriptions": [
            "跟随 VS Code 显示语言",
            "强制中文",
            "Force English"
          ],
          "description": "编辑器界面语言。默认跟随 VS Code，也可手动指定。"
        },
        "behavior3.layout": {
          "type": "string",
          "default": "normal",
          "enum": [
            "normal",
            "compact"
          ],
          "enumDescriptions": [
            "标准布局",
            "紧凑布局"
          ],
          "description": "Behavior Tree 节点布局样式。"
        },
        "behavior3.editSubtreeNodeProps": {
          "type": "boolean",
          "default": true,
          "description": "是否允许在 Inspector 中编辑子树节点的属性（输入/输出/参数等）。启用时可通过 $override 覆盖子树中的节点属性；禁用时子树内部节点为只读。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js && vite build",
    "build:dev": "node esbuild.js --dev && vite build --mode development",
    "watch:ext": "node esbuild.js --watch",
    "watch:webview": "vite build --watch --mode development",
    "dev": "npm run watch:webview",
    "package": "vsce package",
    "postinstall": "git submodule update --init --recursive",
    "check": "tsc --noEmit && tsc --project tsconfig.webview.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "sass": "^1.77.8",
    "tailwindcss": "^3.4.15",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@antv/g6": "^5.0.51",
    "ahooks": "^3.8.0",
    "antd": "^6.3.4",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^7.2.1",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.2.1",
    "react-markdown": "^9.0.1",
    "ts-key-enum": "^2.0.12",
    "typescript": "^5.8.2",
    "usehooks-ts": "^3.1.0",
    "zustand": "^5.0.3"
  }
}
