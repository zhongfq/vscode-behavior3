{
  "name": "vscode-behavior3",
  "displayName": "Behavior Tree Editor",
  "description": "Visual behavior tree editor for game development",
  "version": "0.1.0",
  "publisher": "codetypes",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhongfq/vscode-behavior3"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "behavior3.treeEditor",
        "displayName": "Behavior Tree Editor",
        "selector": [
          {
            "filenamePattern": "*.b3tree"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "behavior3.treeEditor",
        "displayName": "Behavior Tree Editor",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      }
    ],
    "views": {
      "behavior3-sidebar": [
        {
          "type": "webview",
          "id": "behavior3.inspector",
          "name": "Inspector"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "behavior3-sidebar",
          "title": "Behavior Tree",
          "icon": "$(list-tree)"
        }
      ]
    },
    "commands": [
      {
        "command": "behavior3.build",
        "title": "Build Behavior Tree",
        "icon": "$(play)"
      },
      {
        "command": "behavior3.newTree",
        "title": "Behavior Tree: New .b3tree File"
      },
      {
        "command": "behavior3.openSettings",
        "title": "Behavior Tree: Open Node Config (.b3-setting)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "behavior3.build",
          "when": "activeCustomEditorId == 'behavior3.treeEditor'",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "behavior3.newTree",
          "when": "explorerResourceIsFolder",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Behavior Tree Editor",
      "properties": {
        "behavior3.settingFile": {
          "type": "string",
          "default": "",
          "description": "节点定义配置文件路径（相对工作区根目录，留空则自动发现 *.b3-setting 文件）"
        },
        "behavior3.checkExpr": {
          "type": "boolean",
          "default": true,
          "description": "启用表达式校验"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js && vite build",
    "watch:ext": "node esbuild.js --watch",
    "watch:webview": "vite build --watch",
    "dev": "npm run watch:webview",
    "package": "vsce package",
    "postinstall": "git submodule update --init --recursive"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "sass": "^1.77.8",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.8.2",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@antv/g6": "^5.0.45",
    "ahooks": "^3.8.0",
    "antd": "^5.20.0",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^7.2.1",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.2.1",
    "react-markdown": "^9.0.1",
    "ts-key-enum": "^2.0.12",
    "usehooks-ts": "^3.1.0",
    "zustand": "^5.0.3"
  }
}
